APP_NAME=PingWake
APP_ENV=development
APP_VERSION=0.3.0
LOG_LEVEL=INFO
DOCS_ENABLED=true

# Neon normally provides a postgresql:// URL. PingWake automatically adapts it
# for SQLAlchemy + asyncpg and removes unsupported channel_binding parameters.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Generate different, long random values for each key.
PINGWAKE_API_KEY=replace-with-a-long-random-api-key
PINGWAKE_CRON_KEY=replace-with-a-different-long-random-cron-key

MAX_CONCURRENCY=10
DEFAULT_TIMEOUT_SECONDS=10
FAILURES_TO_OPEN_INCIDENT=3
SUCCESSES_TO_RESOLVE_INCIDENT=2

# Discord incident notifications.
NOTIFICATIONS_ENABLED=false
DISCORD_WEBHOOK_URL=
NOTIFICATION_TIMEOUT_SECONDS=10

# Security: private/local networks are blocked by default.
ALLOW_PRIVATE_TARGETS=false
# Optional comma-separated allowlist. Empty means any public hostname is accepted.
ALLOWED_TARGET_HOSTS=
